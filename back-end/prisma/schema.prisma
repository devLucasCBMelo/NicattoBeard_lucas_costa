generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  CLIENT
}

enum AppointmentStatus {
  SCHEDULED
  CANCELED
}

model User {
  id           String        @id @default(uuid())
  name         String
  email        String        @unique
  passwordHash String
  role         UserRole      @default(CLIENT)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  appointments Appointment[]

  @@map("users")
}

model Barber {
  id           String             @id @default(uuid())
  name         String
  age          Int
  hiredAt      DateTime
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  specialties  BarberSpecialty[]
  appointments Appointment[]

  @@map("barbers")
}

model Specialty {
  id           String             @id @default(uuid())
  name         String             @unique
  description  String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  barbers      BarberSpecialty[]
  appointments Appointment[]

  @@map("specialties")
}

model BarberSpecialty {
  barberId     String
  specialtyId  String

  barber       Barber    @relation(fields: [barberId], references: [id], onDelete: Cascade)
  specialty    Specialty @relation(fields: [specialtyId], references: [id], onDelete: Cascade)

  @@id([barberId, specialtyId])
  @@map("barber_specialties")
}

model Appointment {
  id              String             @id @default(uuid())
  userId          String
  barberId        String
  specialtyId     String
  appointmentDate DateTime
  status          AppointmentStatus  @default(SCHEDULED)
  canceledAt      DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  barber          Barber             @relation(fields: [barberId], references: [id], onDelete: Restrict)
  specialty       Specialty          @relation(fields: [specialtyId], references: [id], onDelete: Restrict)

  @@unique([barberId, appointmentDate])
  @@map("appointments")
}